# ============================================================
# Cool Places — environment variables
# ============================================================
# Copy to .env for local dev. On Vercel, set these in the project
# dashboard (Settings → Environment Variables) — do NOT commit .env.

# --- Database (PostgreSQL) ---
# Local dev: docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres
# Production: Vercel Postgres / Neon / Supabase / Railway Postgres.
# Better Auth drizzle adapter requires a Postgres database (not SQLite).
DATABASE_URL=postgresql://user:password@localhost:5432/cool_places

# --- Better Auth ---
# Required: session signing key. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Bare hostname used as the SIWE message domain + basis for the
# synthesized anonymous-wallet email (wallet.${AUTH_DOMAIN}).
# Dev:  localhost
# Prod: coolplaces.example.com  (no protocol, no trailing slash)
AUTH_DOMAIN=localhost

# Full base URL of the running app, including protocol.
# Better Auth uses this for session cookies and CSRF-trusted origin.
# Dev:  http://localhost:3000
# Prod: https://coolplaces.example.com
APP_URL=http://localhost:3000

NODE_ENV=development

# --- Vercel Blob (image upload) ---
# Vercel dashboard → Storage → Blob → create a store → copy the token.
# For local dev you can use the same prod token; files are namespaced.
BLOB_READ_WRITE_TOKEN=

# --- Reown / WalletConnect ---
# https://cloud.reown.com → New Project (platform: AppKit).
# Used both client-side (Reown modal) and server-side (Reown RPC for
# ERC-6492 / ERC-1271 smart-wallet signature verification + the Reown
# Identity API for ENS / CCIP-read lookups).
# NOTE on prod: after first deploy, add your production domain to
# the project's "Allowed Origins" list in cloud.reown.com.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# --- Pinterest OAuth ---
# https://developers.pinterest.com → My Apps → create an app.
# Required for the Pinterest import feature.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# --- Extraction pipeline (AI Gateway + geocoder) ---
# Optional for local dev until the review queue UI is wired.
# AI Gateway: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
# Model to use for extraction (default: openai/gpt-4o-mini)
EXTRACTION_MODEL=openai/gpt-4o-mini
# Mapbox geocoding: https://account.mapbox.com → Tokens
MAPBOX_TOKEN=
# "mapbox" for real geocoding, "mock" for local dev without a token
GEOCODER_PROVIDER=mock
